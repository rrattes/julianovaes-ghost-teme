{{!< default}}

{{#post}}
  <article class="content-page post-page">
    <header class="post-hero">
      <div class="container post-hero-grid">
        <div class="post-hero-copy">
          <a class="back-link" href="/tag/artigos/"><span aria-hidden="true">←</span> Artigos</a>
          <p class="kicker">{{date format="DD/MM/YYYY"}}</p>
          <h1>{{title}}</h1>
          {{#if custom_excerpt}}<p class="post-excerpt">{{custom_excerpt}}</p>{{/if}}
        </div>
        {{#if feature_image}}
          <figure class="post-feature">
            <img src="{{img_url feature_image size="l"}}" alt="{{title}}">
          </figure>
        {{/if}}
      </div>
    </header>

    <div class="container narrow post-content-shell">
      <div class="content-body">
        {{content}}
      </div>
      <footer class="post-footer">
        <a class="text-link" href="/tag/artigos/">Ver todos os artigos <span aria-hidden="true">→</span></a>
      </footer>
    </div>
  </article>
{{/post}}
