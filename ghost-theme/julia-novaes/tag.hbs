{{!< default}}

<section class="content-page tag-articles">
  <div class="container">
    <header class="content-header">
      <p class="kicker">Artigos</p>
      <h1>{{tag.name}}</h1>
      {{#if tag.description}}
        <p>{{tag.description}}</p>
      {{else}}
        <p>Textos sobre vida emocional, vínculos, escolhas e processos de elaboração.</p>
      {{/if}}
    </header>
    <div class="article-grid">
      {{#foreach posts limit="6"}}
        <article class="article-card">
          {{#if feature_image}}
            <img src="{{img_url feature_image size="m"}}" alt="{{title}}">
          {{else}}
            <div class="placeholder-image"></div>
          {{/if}}
          <h3><a href="{{url}}">{{title}}</a></h3>
          <p>{{excerpt words="18"}}</p>
          <a class="read-link" href="{{url}}">Ler artigo <span aria-hidden="true">→</span></a>
        </article>
      {{/foreach}}
    </div>

    {{#get "posts" filter="tag:artigos" limit="all" include="tags,authors" as |all_articles|}}
      {{#foreach all_articles from="7"}}
        {{#if @first}}
          <section class="article-list-section" aria-label="Todos os artigos">
            <div class="article-list-heading">
              <p class="kicker">Arquivo</p>
              <h2>Todos os artigos</h2>
              <p>Outras leituras sobre vida emocional, vínculos, escolhas e processos de elaboração.</p>
            </div>
            <div class="article-list">
        {{/if}}
              <article class="article-list-item">
                <a class="article-list-image" href="{{url}}" aria-label="Ler {{title}}">
                  {{#if feature_image}}
                    <img src="{{img_url feature_image size="s"}}" alt="{{title}}">
                  {{else}}
                    <span class="placeholder-image"></span>
                  {{/if}}
                </a>
                <div class="article-list-content">
                  <p class="article-list-date">{{date format="DD/MM/YYYY"}}</p>
                  <h3 class="article-list-title"><a href="{{url}}">{{title}}</a></h3>
                  <p class="article-list-excerpt">{{excerpt words="28"}}</p>
                  <a class="article-list-link" href="{{url}}">Ler artigo <span aria-hidden="true">→</span></a>
                </div>
              </article>
        {{#if @last}}
            </div>
          </section>
        {{/if}}
      {{/foreach}}
    {{/get}}
  </div>
</section>
