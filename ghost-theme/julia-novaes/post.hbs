{{!< default}}

{{#post}}
  <article class="content-page post-page">
    <header class="post-hero">
      <div class="container post-hero-grid">
        <div class="post-hero-copy">
          <a class="back-link" href="/tag/artigos/"><span aria-hidden="true">←</span> Artigos</a>
          <p class="kicker">{{date format="DD/MM/YYYY"}}</p>
          <h1>{{title}}</h1>
          {{#if custom_excerpt}}<p class="post-excerpt">{{custom_excerpt}}</p>{{/if}}
        </div>
        {{#if feature_image}}
          <figure class="post-feature">
            <img src="{{img_url feature_image size="l"}}" alt="{{title}}">
          </figure>
        {{/if}}
      </div>
    </header>

    <div class="container narrow post-content-shell">
      <div class="content-body">
        {{content}}
      </div>
      <section class="post-contact-cta">
        <p class="kicker">Atendimento psicológico</p>
        <h2>Atendimento psicológico</h2>
        <p>Julia Novaes realiza atendimentos psicológicos particulares para adultos e casais. Informações sobre disponibilidade de agenda podem ser solicitadas pelo site.</p>
        <a class="button" href="https://wa.me/5521999988956?text=Ol%C3%A1%2C%20Julia.%20Gostaria%20de%20solicitar%20disponibilidade%20de%20agenda." target="_blank" rel="noopener noreferrer">Solicitar disponibilidade de agenda</a>
      </section>
      <footer class="post-footer">
        <a class="text-link" href="/tag/artigos/">Ver todos os artigos <span aria-hidden="true">→</span></a>
      </footer>
    </div>
  </article>
{{/post}}
