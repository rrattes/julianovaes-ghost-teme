{{!< default}}

{{#post}}
  <article class="content-page">
    <div class="container narrow">
      {{#if @page.show_title_and_feature_image}}
        <header class="content-header">
          <h1>{{title}}</h1>
          {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{/if}}
          {{#match slug "psicoterapia-particular-online"}}
            <a class="button content-header-cta" href="https://wa.me/5521999988956?text=Ol%C3%A1%2C%20Julia.%20Gostaria%20de%20solicitar%20disponibilidade%20para%20psicoterapia%20particular%20online." target="_blank" rel="noopener noreferrer">Solicitar disponibilidade de agenda</a>
          {{/match}}
          {{#match slug "psicoterapia-online"}}
            <a class="button content-header-cta" href="https://wa.me/5521999988956?text=Ol%C3%A1%2C%20Julia.%20Gostaria%20de%20solicitar%20disponibilidade%20para%20psicoterapia%20online." target="_blank" rel="noopener noreferrer">Solicitar disponibilidade de agenda</a>
          {{/match}}
        </header>
        {{#if feature_image}}
          <img class="post-feature-image" src="{{img_url feature_image size="l"}}" alt="{{title}}">
        {{/if}}
      {{/if}}
      <div class="content-body">
        {{content}}
      </div>
      {{#match slug "atendimentos"}}
        {{> first-contact}}
      {{/match}}
      {{#match slug "psicoterapia-individual"}}
        {{> first-contact}}
      {{/match}}
      {{#match slug "psicoterapia-particular-online"}}
        {{> first-contact}}
